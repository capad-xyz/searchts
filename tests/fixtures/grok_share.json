    {
      "responseId": "44444444-4444-4444-8444-444444444444",
      "message": "Most balcony herbs like the top inch of soil to dry out between waterings. Check with a finger every day or two, and water thoroughly until it drains from the bottom. Pots dry faster in wind and heat, so adjust as summer ramps up.",
      "sender": "assistant",
      "createTime": "2025-05-01T10:01:12.080Z",
      "manual": false,
      "partial": false,
