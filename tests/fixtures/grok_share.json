    {
      "responseId": "22222222-2222-4222-8222-222222222222",
      "message": "Start with hardy, forgiving herbs like basil, mint, and parsley. Grab a few pots with drainage holes, some quality potting mix, and set them where they will catch several hours of sun a day.",
      "sender": "assistant",
      "createTime": "2025-05-01T10:00:00.100Z",
      "manual": false,
